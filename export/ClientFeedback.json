  {
    "client_id": "emma_williams_id",
    "submitted_by": "Rosalind McDonell",
    "submitted_by_relationship": "headteacher",
    "feedback_type": "concern",
    "category": "punctuality",
    "rating": 3,
    "subject": "Attendance and Punctuality Impact on Learning",
    "comments": "While Emma has made excellent academic progress (up 2 years in English and Maths), her attendance and punctuality continue to impact her learning, especially as she's now in Year 11 facing GCSEs. She's a bright student when she's here and engaged, but missing lessons means she's working under her expected level. The 1:1 support is helping, but consistent attendance is crucial this year.",
    "related_staff_id": "katie_robinson_id",
    "related_visit_id": null,
    "status": "in_progress",
    "priority": "medium",
    "assigned_to_staff_id": null,
    "acknowledged_by_staff_id": "katie_robinson_id",
    "acknowledged_date": "2025-01-18T09:00:00Z",
    "response": "Thank you for this feedback Rosalind. We're aware this is an ongoing challenge and have intensified our support. We've implemented: daily wake-up routine with favorite breakfast, incentive schemes linked to attendance, daily revision sessions at home, and keywork on importance of education. The new taxi arrangement should help with punctuality. We're committed to working closely with you to support Emma through Year 11.",
    "response_date": "2025-01-18T15:00:00Z",
    "action_taken": "Increased morning support, incentive scheme, daily revision, closer liaison with school, new transport arrangements with stricter time windows",
