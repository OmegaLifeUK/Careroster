  {
    "client_id": "emma_williams_id",
    "submitted_by": "Carol Williams",
    "submitted_by_relationship": "mother",
    "feedback_type": "compliment",
    "category": "staff_performance",
    "rating": 5,
    "subject": "Excellent Progress and Care",
    "comments": "I want to thank the entire Zeus House team, especially Katie and Ellese, for the amazing care they've given Emma. When she first arrived, I was so worried, but she has come so far. The fact that she's barely self-harmed in over a year is incredible. She's back in school, she's happy, and our relationship is so much better now. The team really listen to her and support her emotional needs. Thank you all.",
    "related_staff_id": null,
    "related_visit_id": null,
    "status": "acknowledged",
    "priority": "low",
    "assigned_to_staff_id": null,
    "acknowledged_by_staff_id": "katie_robinson_id",
    "acknowledged_date": "2025-01-15T10:00:00Z",
    "response": "Thank you so much Carol. Emma has worked incredibly hard and we're so proud of her progress. She's a credit to herself and we're honored to support her journey. Your continued involvement and support has been crucial to her success.",
    "response_date": "2025-01-15T14:00:00Z",
    "action_taken": null,
